datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id           Int              @id @default(autoincrement())
  taxCode      String           @unique
  businessName String
  password     String
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  declarations TaxDeclaration[]
  invoices     Invoice[]
  chatMessages ChatMessage[]
  deadlines    Deadline[]
  posInvoices  PosInvoice[]
}

model TaxDeclaration {
  id        Int      @id @default(autoincrement())
  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  taxType   String // "TNCN", "TNDN", "VAT", "MON_BAI"
  period    String // e.g. "Tháng 05/2026", "Quý 2/2026", "Năm 2026"
  revenue   Float
  expenses  Float    @default(0)
  taxAmount Float
  status    String // "DRAFT", "SUBMITTED"
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Invoice {
  id            Int      @id @default(autoincrement())
  userId        Int
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  invoiceNumber String?
  date          String?
  sellerName    String?
  sellerTaxCode String?
  buyerName     String?
  buyerTaxCode  String?
  itemsJson     String // Serialized JSON array of items
  subtotal      Float?
  vatRate       Float?
  vatAmount     Float?
  total         Float?
  confidence    Float? // Confidence percentage (e.g. 85.5)
  imageUrl      String? // Full absolute URL path of the image for mobile retrieval
  createdAt     DateTime @default(now())
}

model ChatMessage {
  id        Int      @id @default(autoincrement())
  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  sender    String // "USER", "AI"
  content   String
  createdAt DateTime @default(now())
}

model Deadline {
  id        Int      @id @default(autoincrement())
  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  taxType   String // "VAT", "TNCN", "TNDN", "MON_BAI", "OTHER"
  dueDate   DateTime
  status    String // "PENDING", "OVERDUE", "PAID"
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─── POS Module ───────────────────────────────────────────────────────────────

// Danh mục sản phẩm / dịch vụ (dùng chung cho mọi user, seed tự động)
model PosItem {
  id        String   @id
  name      String
  price     Float
  type      String // "FOOD" | "PRODUCT" | "SERVICE"
  imageUrl  String   @default("/uploads/pos-placeholder.svg")
  createdAt DateTime @default(now())
}

// Hoá đơn bán hàng POS của từng user
model PosInvoice {
  id            String   @id
  userId        Int
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  total         Float
  estimatedTax  Float    @default(0)
  itemsJson     String // JSON array of {id, name, price, type, quantity}
  paymentMethod String   @default("CASH") // "CASH" | "QR_BANK" | "CARD"
  createdAt     DateTime @default(now())
}
